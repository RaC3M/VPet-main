<pu:WindowX x:Class="VPet_Simulator.Windows.winActionEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Foreground="{StaticResource PrimaryText}"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:pu="https://opensource.panuon.com/wpf-ui"
        Title="編輯動作" Height="350" Width="450" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Style="{DynamicResource BaseWindowXStyle}"
        Background="{DynamicResource SecondaryLighter}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="動作類型" />
            <ComboBox x:Name="cbActionType" Grid.Column="1" Margin="4,2"
                      SelectionChanged="ActionType_SelectionChanged"
                      Style="{DynamicResource StandardComboBoxStyle}">
                <ComboBoxItem Content="啟動程式" Tag="LaunchProgram" />
                <ComboBoxItem Content="番茄鐘" Tag="StartPomodoro" />
                <ComboBoxItem Content="發送訊息" Tag="SendMessage" />
                <ComboBoxItem Content="等待" Tag="Wait" />
                <ComboBoxItem Content="系統通知" Tag="ShowNotification" />
            </ComboBox>
        </Grid>

        <Grid Grid.Row="1" x:Name="panelProgram" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="程式/檔案" />
            <TextBox x:Name="tbActionProgram" Grid.Column="1" Margin="4,2"
                     Style="{DynamicResource StandardTextBoxStyle}" />
            <Button Grid.Column="2" Margin="4,2" Padding="8,2" Content="瀏覽..."
                    Click="BrowseFile_Click" />
        </Grid>

        <Grid Grid.Row="2" x:Name="panelPomodoro" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="分鐘數" />
            <pu:NumberInput x:Name="numActionPomodoro" Grid.Column="1" Margin="4,2"
                            Minimum="1" Maximum="120" Value="25" />
        </Grid>

        <Grid Grid.Row="3" x:Name="panelMessage" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Top" Text="訊息內容" />
            <TextBox x:Name="tbActionMessage" Grid.Column="1" Margin="4,2" Height="60"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     Style="{DynamicResource StandardTextBoxStyle}" />
        </Grid>

        <Grid Grid.Row="4" x:Name="panelWait" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="等待秒數" />
            <pu:NumberInput x:Name="numActionWait" Grid.Column="1" Margin="4,2"
                            Minimum="1" Maximum="3600" Value="5" />
        </Grid>

        <StackPanel Grid.Row="5" x:Name="panelNotification" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="通知標題" />
                <TextBox x:Name="tbActionNotifTitle" Grid.Column="1" Margin="4,2"
                         Style="{DynamicResource StandardTextBoxStyle}" />
            </Grid>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Top" Text="通知內容" />
                <TextBox x:Name="tbActionNotifBody" Grid.Column="1" Margin="4,2" Height="60"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         Style="{DynamicResource StandardTextBoxStyle}" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="btnActionOK" Margin="0,0,8,0" Padding="16,8" Content="確定"
                    Click="ActionOK_Click" />
            <Button Padding="16,8" Content="取消" Click="ActionCancel_Click" />
        </StackPanel>
    </Grid>
</pu:WindowX>
