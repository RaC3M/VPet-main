<pu:WindowX x:Class="VPet_Simulator.Windows.AiAgent.AiAgentSettingsWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:pu="clr-namespace:Panuon.WPF.UI;assembly=Panuon.WPF.UI"
            Title="AI Agent Settings"
            Width="590"
            Height="650"
            WindowStartupLocation="CenterScreen"
            Background="{DynamicResource PrimaryLighter}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="165" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,14" TextWrapping="Wrap"
                   Text="Default provider is local Ollama. The AI role uses the pet name, owner name, live pet status, and calendar context." />

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Pet Name" />
        <TextBox x:Name="tbPetName" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" />

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Owner Name" />
        <TextBox x:Name="tbOwnerName" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" />

        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Provider" />
        <ComboBox x:Name="cbProvider" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
            <ComboBoxItem Content="Ollama" Tag="ollama" />
            <ComboBoxItem Content="OpenAI" Tag="openai" />
        </ComboBox>

        <CheckBox x:Name="cbOllamaAutoStart" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"
                  Content="Start and preload Ollama when the pet starts" />

        <CheckBox x:Name="cbStartWithWindows" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10"
                  Content="Start desktop pet with Windows" />

        <CheckBox x:Name="cbWebSearch" Grid.Row="6" Grid.Column="1" Margin="0,0,0,10" Visibility="Collapsed"
                  Content="Enable web search for current information" />

        <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Vertex Project ID" Visibility="Collapsed" />
        <TextBox x:Name="tbVertexSearchProjectId" Grid.Row="7" Grid.Column="1" Margin="0,0,0,10" Visibility="Collapsed" />

        <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="Vertex App ID" Visibility="Collapsed" />
        <TextBox x:Name="tbVertexSearchAppId" Grid.Row="8" Grid.Column="1" Margin="0,0,0,10" Visibility="Collapsed" />

        <TextBlock Grid.Row="9" Grid.Column="0" VerticalAlignment="Center" Text="Vertex Location" Visibility="Collapsed" />
        <TextBox x:Name="tbVertexSearchLocation" Grid.Row="9" Grid.Column="1" Margin="0,0,0,10" Visibility="Collapsed" />

        <TextBlock Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Text="Vertex API Key" Visibility="Collapsed" />
        <PasswordBox x:Name="pbVertexSearchApiKey" Grid.Row="10" Grid.Column="1" Margin="0,0,0,10" Visibility="Collapsed" />

        <TextBlock Grid.Row="11" Grid.Column="0" VerticalAlignment="Center" Text="Ollama URL" />
        <TextBox x:Name="tbOllamaUrl" Grid.Row="11" Grid.Column="1" Margin="0,0,0,10" />

        <TextBlock Grid.Row="12" Grid.Column="0" VerticalAlignment="Center" Text="Ollama Model" />
        <ComboBox x:Name="cbOllamaModel" Grid.Row="12" Grid.Column="1" Margin="0,0,0,10"
                  IsEditable="True" IsTextSearchEnabled="False">
            <ComboBoxItem Content="Qwen2.5 1.5B - light" Tag="qwen2.5:1.5b" />
            <ComboBoxItem Content="Qwen2.5 3B - balanced small" Tag="qwen2.5:3b" />
            <ComboBoxItem Content="Qwen2.5 7B - recommended Chinese" Tag="qwen2.5:7b" />
            <ComboBoxItem Content="Qwen2.5 14B - stronger, heavier" Tag="qwen2.5:14b" />
            <ComboBoxItem Content="Llama 3.2 1B - very light" Tag="llama3.2:1b" />
            <ComboBoxItem Content="Llama 3.2 3B - light agent" Tag="llama3.2:3b" />
            <ComboBoxItem Content="Gemma 3 1B - very light" Tag="gemma3:1b" />
            <ComboBoxItem Content="Gemma 3 4B - balanced" Tag="gemma3:4b" />
            <ComboBoxItem Content="Gemma 3 12B - stronger, heavier" Tag="gemma3:12b" />
        </ComboBox>

        <TextBlock Grid.Row="13" Grid.Column="0" VerticalAlignment="Center" Text="OpenAI API Key" />
        <PasswordBox x:Name="pbOpenAiKey" Grid.Row="13" Grid.Column="1" Margin="0,0,0,10" />

        <TextBlock Grid.Row="14" Grid.Column="0" VerticalAlignment="Center" Text="OpenAI Model" />
        <TextBox x:Name="tbOpenAiModel" Grid.Row="14" Grid.Column="1" Margin="0,0,0,10" />

        <TextBlock Grid.Row="15" Grid.Column="0" VerticalAlignment="Center" Text="Google Client ID" />
        <TextBox x:Name="tbGoogleClientId" Grid.Row="15" Grid.Column="1" Margin="0,0,0,10" />

        <TextBlock Grid.Row="16" Grid.Column="0" VerticalAlignment="Top" Text="Google Client Secret" />
        <StackPanel Grid.Row="16" Grid.Column="1">
            <PasswordBox x:Name="pbGoogleClientSecret" Margin="0,0,0,10" />
            <TextBlock x:Name="tbStatus" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="17" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Margin="0,0,8,0" Padding="12,6" Content="Save" Click="Save_Click" />
            <Button Margin="0,0,8,0" Padding="12,6" Content="Download Ollama Model" Click="DownloadOllamaModel_Click" />
            <Button Margin="0,0,8,0" Padding="12,6" Content="Test AI" Click="TestAi_Click" />
            <Button Margin="0,0,8,0" Padding="12,6" Content="Connect Google" Click="ConnectGoogle_Click" />
            <Button Padding="12,6" Content="Close" Click="Close_Click" />
        </StackPanel>
    </Grid>
</pu:WindowX>
