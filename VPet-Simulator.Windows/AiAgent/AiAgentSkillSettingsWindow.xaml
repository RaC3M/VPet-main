<pu:WindowX x:Class="VPet_Simulator.Windows.AiAgent.AiAgentSkillSettingsWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:pu="clr-namespace:Panuon.WPF.UI;assembly=Panuon.WPF.UI"
            Title="AI Agent Skill Settings"
            Width="760"
            Height="560"
            WindowStartupLocation="CenterScreen"
            Background="{DynamicResource PrimaryLighter}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="提醒事項">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="標題" />
                        <TextBox x:Name="tbReminderTitle" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="日期" />
                        <DatePicker x:Name="dpReminderDate" Grid.Row="1" Grid.Column="1" Margin="0,0,8,8" />
                        <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="時間" />
                        <TextBox x:Name="tbReminderTime" Grid.Row="1" Grid.Column="3" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="備註" />
                        <TextBox x:Name="tbReminderNote" Grid.Row="2" Grid.Column="1" Margin="0,0,8,0" />
                        <Button Grid.Row="2" Grid.Column="2" Margin="0,0,8,0" Padding="10,5" Content="新增" Click="AddReminder_Click" />
                        <Button Grid.Row="2" Grid.Column="3" Padding="10,5" Content="刪除選取" Click="DeleteReminder_Click" />
                    </Grid>

                    <DataGrid x:Name="dgReminders" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="時間" Binding="{Binding Time, StringFormat=yyyy-MM-dd HH:mm}" Width="150" />
                            <DataGridTextColumn Header="標題" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="備註" Binding="{Binding Note}" Width="*" />
                            <DataGridCheckBoxColumn Header="已觸發" Binding="{Binding Triggered}" Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="程式捷徑">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="名稱" />
                        <TextBox x:Name="tbShortcutName" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="路徑" />
                        <TextBox x:Name="tbShortcutPath" Grid.Row="1" Grid.Column="1" Margin="0,0,8,0" />
                        <Button Grid.Row="1" Grid.Column="2" Margin="0,0,8,0" Padding="10,5" Content="瀏覽" Click="BrowseShortcut_Click" />
                        <Button Grid.Row="1" Grid.Column="3" Margin="0,0,8,0" Padding="10,5" Content="儲存" Click="SaveShortcut_Click" />
                        <Button Grid.Row="1" Grid.Column="4" Padding="10,5" Content="刪除" Click="DeleteShortcut_Click" />
                    </Grid>

                    <DataGrid x:Name="dgShortcuts" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名稱" Binding="{Binding Name}" Width="180" />
                            <DataGridTextColumn Header="路徑" Binding="{Binding Path}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="檔案搜尋說明">
                <TextBlock Margin="14" TextWrapping="Wrap"
                           Text="檔案搜尋 skill 會搜尋所有可存取磁碟的檔名，不搜尋檔案內容。每次最多 15 秒、最多回傳 30 筆，遇到無權限資料夾會略過。例：幫我找 report.pdf" />
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Margin="0,0,8,0" Padding="12,6" Content="重新整理" Click="Refresh_Click" />
            <Button Padding="12,6" Content="關閉" Click="Close_Click" />
        </StackPanel>
    </Grid>
</pu:WindowX>
