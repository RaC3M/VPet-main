[
  {
    "Name": "開始寫程式",
    "Description": "說「開始寫程式」→ 開 IDE + 啟動番茄鐘 + 桌寵鼓勵",
    "Enabled": true,
    "Trigger": {
      "Type": "Input",
      "InputKeyword": "開始寫程式"
    },
    "Actions": [
      { "Type": "LaunchProgram", "ProgramName": "notepad", "DelaySeconds": 0 },
      { "Type": "SendMessage", "Message": "好喔，一起專心寫程式吧！我幫你開了編輯器也啟動番茄鐘了～", "DelaySeconds": 2 },
      { "Type": "StartPomodoro", "PomodoroMinutes": 25, "DelaySeconds": 1 }
    ]
  },
  {
    "Name": "休息提醒",
    "Description": "每2小時提醒休息",
    "Enabled": true,
    "Trigger": {
      "Type": "Schedule",
      "ScheduleCron": "0 */2 * * *"
    },
    "Actions": [
      { "Type": "SendMessage", "Message": "已經專心兩小時了，起來走走喝杯水吧！", "DelaySeconds": 0 }
    ]
  }
]
